# ════════════════════════════════════════
# ShivMLAI — Root .gitignore
# NEVER push .env files — they have secrets
# ════════════════════════════════════════

# ── ENV FILES (MOST IMPORTANT) ──────────
.env
.env.local
.env.development
.env.production
.env.test
**/.env
**/.env.*
!**/.env.example

# ── Node.js ──────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log

# ── React Build ───────────────────────────
frontend/build/
frontend/.pnp
frontend/.pnp.js

# ── Python / FastAPI ──────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyc
.venv/
venv/
env/
*.egg-info/
dist/
.pytest_cache/

# ── OS Files ──────────────────────────────
.DS_Store
Thumbs.db
*.log

# ── IDE ───────────────────────────────────
.vscode/settings.json
.idea/
*.swp
